{
  "_comment": "Import this into n8n. Fires every Sunday at 9:00am.",
  "_nodes": [
    {
      "name": "Cron - Sunday 9am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 * * 0" }] }
      }
    },
    {
      "name": "Fetch this week's expenses",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "https://{{ $env.SUPABASE_URL }}/rest/v1/expenses",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "date,concept,category,amount,account" },
            { "name": "date", "value": "gte.{{ $now.minus(7, 'days').toFormat('yyyy-MM-dd') }}" },
            { "name": "order", "value": "date.desc" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "{{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "Bearer {{ $env.SUPABASE_ANON_KEY }}" }
          ]
        }
      }
    },
    {
      "name": "Fetch accounts (for net worth)",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "https://{{ $env.SUPABASE_URL }}/rest/v1/accounts",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "select", "value": "name,balance,type" }]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "{{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "Bearer {{ $env.SUPABASE_ANON_KEY }}" }
          ]
        }
      }
    },
    {
      "name": "Claude Haiku - spending summary",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "{{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "body": {
          "model": "claude-haiku-4-5-20251001",
          "max_tokens": 400,
          "messages": [
            {
              "role": "user",
              "content": "Eres el asistente financiero personal de Edu (Barcelona). Tu presupuesto mensual total es ~€2002.\n\nGastos de esta semana:\n{{ JSON.stringify($node['Fetch this week\\'s expenses'].json, null, 2) }}\n\nPatrimonio actual por cuenta:\n{{ JSON.stringify($node['Fetch accounts (for net worth)'].json, null, 2) }}\n\nEscribe un resumen semanal en español, máximo 5 frases. Incluye: total gastado esta semana, categoría donde más se gastó, algo positivo y una sugerencia concreta para la semana que viene. Sé directo, sin saludos ni despedidas."
            }
          ]
        }
      }
    },
    {
      "name": "Send to Telegram",
      "type": "n8n-nodes-base.telegram",
      "parameters": {
        "operation": "sendMessage",
        "chatId": "{{ $env.TELEGRAM_CHAT_ID }}",
        "text": "📊 *Resumen semanal Life OS*\n\n{{ $node['Claude Haiku - spending summary'].json.content[0].text }}",
        "additionalFields": { "parse_mode": "Markdown" }
      }
    },
    {
      "name": "Snapshot net worth",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "https://{{ $env.SUPABASE_URL }}/rest/v1/rpc/snapshot_net_worth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "{{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "Bearer {{ $env.SUPABASE_ANON_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "body": {}
      }
    }
  ]
}
